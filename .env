# ============================================
# Oftalmología SI1 — Clínica de Ojos Norte
# Variables de Entorno (DESARROLLO LOCAL)
# ============================================
# --- Cambiar solo IP o dominio (mismo esquema/puertos) -----------------------
# Reemplazá TU_IP y, si aplica, el puerto del front (HOST_PORT_FRONTEND):
#   DJANGO_ALLOWED_HOSTS=... incluir TU_IP o el dominio
#   CORS_ALLOWED_ORIGINS=http://TU_IP:3000,...   (origen del navegador del panel)
#   FRONTEND_URL=http://TU_IP:3000
#   NEXT_PUBLIC_API_URL=http://TU_IP:8000/api

# ---- General ----
COMPOSE_PROJECT_NAME=oftalmologia-si1

# ---- PostgreSQL ----
POSTGRES_DB=oftalmologia_si1_db
POSTGRES_USER=oftalmologia_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Django Backend ----
DJANGO_SECRET_KEY=CHANGE_ME_GENERATE_A_SECRET_KEY
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT (tiempos en minutos/días)
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=7

# ---- Email (Mailhog en Docker dev) ----
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@clinicaojnorte.local
FRONTEND_URL=http://localhost:3000

# ---- Next.js Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api
INTERNAL_API_URL=http://backend:8000/api
NEXT_PUBLIC_APP_NAME=Clínica de Ojos Norte

# ----External services  ----
